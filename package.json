{
  "name": "codetracer-js-recorder",
  "version": "0.1.0",
  "private": true,
  "description": "CodeTracer JavaScript/TypeScript recorder — full-state recording via compile-time SWC instrumentation",
  "workspaces": [
    "packages/instrumenter",
    "packages/runtime",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run && npm run test:verify-cli-convention",
    "test:watch": "vitest",
    "test:verify-cli-convention": "bash tests/verify-cli-convention-no-silent-skip.sh"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
